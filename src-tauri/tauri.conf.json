{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "stream-desktop",
  "version": "0.0.1",
  "identifier": "com.stream.desktop",

  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "stream-desktop",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],

    "security": {
      "capabilities": [
        "default"
      ]
    }
  },

  "bundle": {
    "active": true,
    "targets": "all"
  }
}